# SweeTTY instance configuration (single source of truth for one host).
#
# Copy this file to sweetty.instance.env and fill it in. The real file is
# gitignored because it carries host-specific values (your management IP, your
# log endpoint). provision.sh, the nftables renderer, and deploy.sh all source
# it. Keep it shell-safe: KEY=value, no spaces around the '=', quote when needed.

# ---------------------------------------------------------------------------
# Release pinning. Never deploy 'latest'. Pin an explicit tag and bump it on
# purpose. The deploy verifies the artifact against checksums.txt before swap.
# ---------------------------------------------------------------------------
SWEETTY_REPO="adrianmcphee/sweetty"
RELEASE_TAG="v0.1.6"
# The blue/green deploy runtime. provision.sh fetches and checksum-verifies this
# static binary so the host needs no Go toolchain. Pin both and bump on purpose.
SLOTDEPLOY_REPO="adrianmcphee/slotdeploy"
SLOTDEPLOY_VERSION="v0.1.0"

# ---------------------------------------------------------------------------
# Identity and paths. The honeypot runs as a dedicated, unprivileged system
# user. Treat that user as already hostile (assume-escape threat model).
# ---------------------------------------------------------------------------
SWEETTY_USER="sweetty"
INSTALL_DIR="/opt/sweetty"
DEPLOY_USER="deploy"

# ---------------------------------------------------------------------------
# Management plane. Only the real management SSH is exposed, and only to this
# operator address; everything else on the box is the attack surface, open to
# the world. The portal is NOT exposed: it binds loopback and you reach it by
# forwarding the SSH port to it:
#   ssh -L 8888:127.0.0.1:${PORTAL_PORT} deploy@host -p ${ADMIN_SSH_PORT}
# then open http://localhost:8888. SSH key auth is the front door, so the portal
# itself needs no login. Use a single host (a.b.c.d) or a CIDR (a.b.c.0/24).
#
# IMPORTANT: set this to the address YOU connect from. Admin SSH is firewalled to
# it alone, so a wrong or stale value locks you out of your own box (rebuild
# required). An all-internet wildcard (0.0.0.0/0, ::/0, any /0) is rejected by the
# renderer, so you cannot accidentally open management to the world.
# ---------------------------------------------------------------------------
OPERATOR_IP="203.0.113.10"
# Optional IPv6 management source (single host or CIDR). Leave empty to keep IPv6
# management closed; it defaults to ::1, which matches nothing reachable.
OPERATOR_IP6=""
# Leave ADMIN_SSH_PORT empty to randomize it per instance from a pool of
# http-like ports (8088 and friends) so the real SSH blends in as a web service
# rather than an obvious admin port; provision.sh picks one and records it here.
# For unattended (cloud-init) provisioning, set it explicitly so you know which
# port to reconnect on: a randomized one is only readable from the provider console
# or /root/sweetty.instance.env on the box.
ADMIN_SSH_PORT=""
# Loopback port the portal binds and the SSH tunnel targets. Not firewall-opened.
PORTAL_PORT="8888"

# ---------------------------------------------------------------------------
# Egress. A honeypot should almost never talk outbound. Egress is denied by
# default and the honeypot user is denied egress entirely. These values open a
# tight allowlist for the few host functions that legitimately need the network
# (DNS, pulling a pinned release, shipping logs).
# ---------------------------------------------------------------------------
# IPv4 resolvers only: the firewall matches them with `ip daddr`, so an IPv6
# resolver here would make the rendered ruleset fail its syntax check.
DNS_RESOLVERS="1.1.1.1,9.9.9.9"
# Log-shipping collector the host forwards sweetty.log to. host:port form.
# Leave empty to disable off-host shipping (not recommended).
LOG_ENDPOINT="logs.example.com:6514"
# tcp or tls for the log transport (tls strongly recommended off-host). With tls,
# provision installs rsyslog-gnutls and forwards over TLS; if it cannot, it
# refuses to ship rather than fall back to plaintext.
LOG_TRANSPORT="tls"
# CA bundle that verifies the collector's TLS certificate when LOG_TRANSPORT=tls.
# Empty uses the system bundle (/etc/ssl/certs/ca-certificates.crt).
LOG_CA=""
# Session recordings (asciinema casts) land in /opt/sweetty/recordings per
# config.json and replay in the portal. Keep them this many days before a
# systemd-tmpfiles rule ages them out, so a busy sensor cannot fill its disk.
RECORD_RETENTION_DAYS="14"

# ---------------------------------------------------------------------------
# Edge topology.
#   haproxy : HAProxy TCP edge in front (default). A transparent PROXY-protocol
#             passthrough that preserves the real attacker IP, sheds obvious
#             floods with gentle per-source limits (logged as FLOOD_BLOCKED), and
#             reverse-proxies a stats console into the portal over the SSH tunnel.
#   direct  : sweetty binds the public honeypot ports itself, no proxy.
# See haproxy/README.md.
# ---------------------------------------------------------------------------
TOPOLOGY="haproxy"
